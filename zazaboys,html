<script>
// ==========================================
// REPRODUCTOR DE VIDEO ZAZABOYS (VARIABLES RENOMBRADAS)
// ==========================================

const zazaVideo = document.getElementById('zazaVideo');
const videoPlayBtn = document.getElementById('playPauseBtn');
const videoOverlay = document.getElementById('videoOverlay');
const videoProgressBar = document.getElementById('progressBar');
const videoProgressHandle = document.getElementById('progressHandle');
const videoCurrentTime = document.getElementById('currentTime');
const videoDuration = document.getElementById('duration');

let isVideoPlaying = false;

function toggleVideo() {
    if (zazaVideo.paused) {
        zazaVideo.muted = false; // Asegurar que no esté mute
        zazaVideo.volume = 1.0;  // Volumen al máximo
        zazaVideo.play();
        isVideoPlaying = true;
        videoPlayBtn.classList.add('playing');
        videoPlayBtn.innerHTML = '<span class="play-icon">⏸</span>';
        videoOverlay.classList.add('hidden');
    } else {
        zazaVideo.pause();
        isVideoPlaying = false;
        videoPlayBtn.classList.remove('playing');
        videoPlayBtn.innerHTML = '<span class="play-icon">▶</span>';
        videoOverlay.classList.remove('hidden');
    }
}

// Click en el video para pausar/reproducir
zazaVideo.addEventListener('click', toggleVideo);

// Actualizar barra de progreso
zazaVideo.addEventListener('timeupdate', () => {
    const progress = (zazaVideo.currentTime / zazaVideo.duration) * 100;
    videoProgressBar.style.width = progress + '%';
    videoProgressHandle.style.left = progress + '%';
    videoCurrentTime.textContent = formatVideoTime(zazaVideo.currentTime);
});

// Cuando el video termina
zazaVideo.addEventListener('ended', () => {
    isVideoPlaying = false;
    videoPlayBtn.classList.remove('playing');
    videoPlayBtn.innerHTML = '<span class="play-icon">▶</span>';
    videoOverlay.classList.remove('hidden');
    videoProgressBar.style.width = '0%';
    videoProgressHandle.style.left = '0%';
});

// Cargar duración total
zazaVideo.addEventListener('loadedmetadata', () => {
    videoDuration.textContent = formatVideoTime(zazaVideo.duration);
});

// Seek (adelantar/retroceder)
function seekVideo(e) {
    const rect = e.currentTarget.getBoundingClientRect();
    const pos = (e.clientX - rect.left) / rect.width;
    zazaVideo.currentTime = pos * zazaVideo.duration;
}

// Formatear tiempo (0:00)
function formatVideoTime(seconds) {
    if (isNaN(seconds)) return '0:00';
    const mins = Math.floor(seconds / 60);
    const secs = Math.floor(seconds % 60);
    return mins + ':' + (secs < 10 ? '0' : '') + secs;
}

// Mostrar controles al mover el mouse sobre el video
let videoControlsTimeout;
const videoContainer = document.querySelector('.video-container');

videoContainer.addEventListener('mousemove', () => {
    if (isVideoPlaying) {
        videoPlayBtn.style.opacity = '1';
        clearTimeout(videoControlsTimeout);
        videoControlsTimeout = setTimeout(() => {
            if (isVideoPlaying) {
                videoPlayBtn.style.opacity = '0';
            }
        }, 2000);
    }
});

videoContainer.addEventListener('mouseleave', () => {
    if (isVideoPlaying) {
        videoPlayBtn.style.opacity = '0';
    }
});
</script>
    <!-- Título de sección -->
    <h2 class="section-title">📀 Nuestros Lanzamientos</h2>

    <!-- Contenedor de ÁLBUM/CANCIÓNes -->
    <section id="albumes-container">
        <div style="text-align: center; color: #666; padding: 40px; grid-column: 1/-1;">
            <p>Cargando ÁLBUM/CANCIÓN...</p>
        </div>
    </section>

    <!-- Modal de Login -->
    <div id="loginModal" class="modal-overlay">
        <div class="modal-content">
            <span class="close-modal" onclick="closeModal('loginModal')">&times;</span>
            <h2 class="modal-title">🔒 Acceso Protegido</h2>
            <input type="password" id="passwordInput" class="zaza-input" placeholder="Ingresa la contraseña...">
            <button class="zaza-btn" onclick="checkPassword()">INGRESAR</button>
                 <br>  <br><button style="background: rgb(105, 105, 105) !important; color: #fff;" class="zaza-btn" onclick="closeModal('loginModal')">VOLVER</button>  <p id="errorMsg" class="error-msg">❌ Contraseña incorrecta</p>
        </div>

    <!-- Modal de Confirmación -->
    <div id="confirmModal" class="modal-overlay">
        <div class="modal-content" style="max-width: 400px;">
            <span class="close-modal" onclick="closeModal('confirmModal')">&times;</span>
            <div style="text-align: center; padding: 20px;">
                <div style="font-size: 4rem; margin-bottom: 20px;">⚠️</div>
                <h3 style="color: var(--amarillo); margin-bottom: 15px;">¿Confirmar?</h3>
                <p id="confirmMessage" style="color: #ccc; margin-bottom: 25px;">¿Estás seguro?</p>
                <button class="zaza-btn" id="btnConfirmarSi" style="margin-bottom: 10px;">
                    ✅ SÍ, CONFIRMAR
                </button>
                <button class="zaza-btn-secondary" onclick="closeModal('confirmModal')" style="background: #444;">
                    CANCELAR
                </button>
            </div>
        </div>
    </div>

    <script>
        // ==========================================
        // CONFIGURACIÓN FIREBASE
        // ==========================================
        const firebaseConfig = {
            apiKey: "AIzaSyDgsdb0dO0oedOMw3HZLzOpzar5Z76Zq74",
            authDomain: "zazahousestudios-8b7ca.firebaseapp.com",
            databaseURL: "https://zazahousestudios-default-rtdb.firebaseio.com",
            projectId: "zazahousestudios-8b7ca",
            storageBucket: "zazahousestudios-8b7ca.appspot.com",
            messagingSenderId: "560815486667",
            appId: "1:560815486667:web:f521727dd900f255f28d4e"
        };

        // Inicializar Firebase
        let app, db;
        let albumes = [];
        let isAdmin = false;
        let modoEliminar = false;
        let fotoTemporal = null;
        let guardando = false;
        let idAEliminar = null;

        try {
            app = firebase.initializeApp(firebaseConfig);
            db = firebase.database();
            
            console.log('✅ Firebase inicializado');
            document.getElementById('firebaseStatus').textContent = 'Conectado';
            document.getElementById('firebaseStatus').style.color = 'var(--verde)';
            
            // Escuchar cambios en tiempo real
            db.ref('albums').on('value', (snapshot) => {
                const nuevosAlbumes = [];
                if (snapshot.exists()) {
                    snapshot.forEach((child) => {
                        nuevosAlbumes.push({ id: child.key, ...child.val() });
                    });
                    // Ordenar por fecha de creación (más reciente primero)
                    nuevosAlbumes.sort((a, b) => (b.createdAt || 0) - (a.createdAt || 0));
                }
                albumes = nuevosAlbumes;
                localStorage.setItem('zazaboys_albums_backup', JSON.stringify(albumes));
                document.getElementById('albumCount').textContent = albumes.length;
                renderAlbumes();
            }, (error) => {
                console.warn('⚠️ Error Firebase, usando localStorage:', error);
                usarDatosLocales();
            });

        } catch (error) {
            console.error('❌ Error inicializando Firebase:', error);
            document.getElementById('firebaseStatus').textContent = 'Error';
            document.getElementById('firebaseStatus').style.color = '#ff4444';
            usarDatosLocales();
        }

        // Cargar desde localStorage como backup
        function usarDatosLocales() {
            try {
                const backup = localStorage.getItem('zazaboys_albums_backup');
                if (backup) {
                    albumes = JSON.parse(backup);
                    renderAlbumes();
                }
            } catch (e) {
                console.error('Error localStorage:', e);
            }
        }

        // ==========================================
        // EFECTOS VISUALES
        // ==========================================
        function createParticles() {
            const container = document.getElementById('particles');
            for (let i = 0; i < 50; i++) {
                const particle = document.createElement('div');
                particle.className = 'particle';
                particle.style.left = Math.random() * 100 + '%';
                particle.style.animationDelay = Math.random() * 10 + 's';
                particle.style.background = ['var(--fuxia)', 'var(--verde)', 'var(--amarillo)'][Math.floor(Math.random() * 3)];
                container.appendChild(particle);
            }
        }
        createParticles();

        // ==========================================
        // REPRODUCTOR
        // ==========================================
        let isPlaying = false;
        function togglePlay() {
            const btn = document.getElementById('playBtn');
            const audio = document.getElementById('audioPlayer');
            
            if (!audio.src) {
                alert('Selecciona una canción para reproducir');
                return;
            }
            
            if (isPlaying) {
                audio.pause();
                btn.innerHTML = '▶';
                btn.classList.remove('playing');
                btn.style.background = 'var(--fuxia)';
            } else {
                audio.play();
                btn.innerHTML = '⏸';
                btn.classList.add('playing');
                btn.style.background = '#444';
            }
            isPlaying = !isPlaying;
        }

        // ==========================================
        // MODALES
        // ==========================================
        function openLoginModal() {
            document.getElementById('loginModal').classList.add('active');
            document.getElementById('passwordInput').value = '';
            document.getElementById('errorMsg').style.display = 'none';
            document.getElementById('passwordInput').focus();
        }

        function closeModal(modalId) {
            document.getElementById(modalId).classList.remove('active');
        }

        function checkPassword() {
            const password = document.getElementById('passwordInput').value;
            if (password === '1109') {
                isAdmin = true;
                closeModal('loginModal');
                openCreateModal();
            } else {
                const errorMsg = document.getElementById('errorMsg');
                errorMsg.style.display = 'block';
                const input = document.getElementById('passwordInput');
                input.style.borderColor = '#ff4444';
                setTimeout(() => {
                    input.style.borderColor = '';
                }, 1000);
            }
        }

        function openCreateModal() {
            limpiarFormulario();
            document.getElementById('modalTitle').textContent = '🎵 Crear Nuevo ÁLBUM/CANCIÓN';
            document.getElementById('createModal').classList.add('active');
        }

        // ==========================================
        // MODO ELIMINAR
        // ==========================================
        function activarModoEliminar() {
            closeModal('createModal');
            modoEliminar = true;
            document.getElementById('modoEliminarBanner').classList.add('active');
            renderAlbumes();
        }

        function desactivarModoEliminar() {
            modoEliminar = false;
            document.getElementById('modoEliminarBanner').classList.remove('active');
            renderAlbumes();
        }

        // ==========================================
        // FORMULARIO Y PREVIEW
        // ==========================================
        function previewImage(input) {
            const file = input.files[0];
            if (!file) return;

            const reader = new FileReader();
            reader.onload = (e) => {
                fotoTemporal = e.target.result;
                document.getElementById('previewImg').src = fotoTemporal;
                document.getElementById('previewImg').style.display = 'block';
                document.getElementById('fileLabel').innerHTML = '📷 Cambiar imagen (' + file.name + ')';
                document.getElementById('btnQuitarFoto').style.display = 'block';
            };
            reader.readAsDataURL(file);
        }

        function quitarFoto() {
            fotoTemporal = null;
            document.getElementById('albumImage').value = '';
            document.getElementById('previewImg').style.display = 'none';
            document.getElementById('fileLabel').innerHTML = '📷 Seleccionar imagen del ÁLBUM/CANCIÓN';
            document.getElementById('btnQuitarFoto').style.display = 'none';
        }

        function limpiarFormulario() {
            document.getElementById('albumId').value = '';
            document.getElementById('albumTitle').value = '';
            document.getElementById('albumDesc').value = '';
            document.getElementById('linkSpotify').value = '';
            document.getElementById('linkApple').value = '';
            document.getElementById('linkSoundCloud').value = '';
            document.getElementById('linkYouTube').value = '';
            document.getElementById('linkAudiomack').value = '';
            quitarFoto();
            document.getElementById('loadingMsg').style.display = 'none';
            document.getElementById('successMsg').style.display = 'none';
            document.getElementById('saveAlbumBtn').disabled = false;
            document.getElementById('saveAlbumBtn').innerHTML = '💾 GUARDAR ÁLBUM/CANCIÓN';
        }

        // ==========================================
        // GUARDAR ÁLBUM/CANCIÓN (CREAR O EDITAR)
        // ==========================================
        async function guardarAlbum() {
            if (guardando) {
                console.log('⏳ Ya se está guardando...');
                return;
            }

            const id = document.getElementById('albumId').value;
            const esEdicion = !!id;
            const titulo = document.getElementById('albumTitle').value.trim();

            if (!titulo) {
                alert('⚠️ El nombre del ÁLBUM/CANCIÓN es obligatorio');
                document.getElementById('albumTitle').focus();
                return;
            }

            guardando = true;
            const btn = document.getElementById('saveAlbumBtn');
            const textoOriginal = btn.innerHTML;
            btn.innerHTML = '⏳ Guardando...';
            btn.disabled = true;
            document.getElementById('loadingMsg').style.display = 'block';
            document.getElementById('successMsg').style.display = 'none';

            try {
                // Preparar datos
                const data = {
                    title: titulo,
                    description: document.getElementById('albumDesc').value.trim() || 'Sin descripción',
                    links: {
                        spotify: document.getElementById('linkSpotify').value.trim() || '',
                        apple: document.getElementById('linkApple').value.trim() || '',
                        soundcloud: document.getElementById('linkSoundCloud').value.trim() || '',
                        youtube: document.getElementById('linkYouTube').value.trim() || '',
                        audiomack: document.getElementById('linkAudiomack').value.trim() || ''
                    },
                    updatedAt: Date.now()
                };

                // Manejar imagen
                if (fotoTemporal) {
                    // Comprimir imagen antes de guardar
                    data.image = await comprimirImagen(fotoTemporal);
                } else if (esEdicion) {
                    // Mantener imagen existente
                    const existente = albumes.find(a => a.id === id);
                    if (existente?.image) {
                        data.image = existente.image;
                    } else {
                        data.image = 'https://i.ibb.co/C5mFsQnb/logozazahousestudiosoriginal.jpg';
                    }
                } else {
                    // Imagen por defecto
                    data.image = 'https://i.ibb.co/C5mFsQnb/logozazahousestudiosoriginal.jpg';
                }

                if (esEdicion) {
                    // ========== EDITAR ==========
                    console.log('✏️ Editando ÁLBUM/CANCIÓN:', id);
                    
                    // Actualizar en Firebase
                    if (db && !id.startsWith('local-')) {
                        try {
                            await db.ref('albums/' + id).update(data);
                            console.log('✅ Actualizado en Firebase');
                        } catch (firebaseError) {
                            console.warn('⚠️ Error Firebase:', firebaseError);
                        }
                    }
                    
                    // Actualizar en array local
                    const idx = albumes.findIndex(a => a.id === id);
                    if (idx >= 0) {
                        albumes[idx] = { ...albumes[idx], ...data };
                    }
                    
                } else {
                    // ========== CREAR NUEVO ==========
                    console.log('🎵 Creando nuevo ÁLBUM/CANCIÓN');
                    
                    data.createdAt = Date.now();
                    
                    let newId;
                    
                    // Intentar crear en Firebase
                    if (db) {
                        try {
                            const nuevoRef = db.ref('albums').push();
                            await nuevoRef.set(data);
                            newId = nuevoRef.key;
                            console.log('✅ Creado en Firebase:', newId);
                        } catch (firebaseError) {
                            console.warn('⚠️ Error Firebase, creando local:', firebaseError);
                            newId = 'local-' + Date.now();
                        }
                    } else {
                        newId = 'local-' + Date.now();
                    }
                    
                    // Agregar al array local
                    albumes.unshift({ id: newId, ...data });
                }

                // Guardar en localStorage
                localStorage.setItem('zazaboys_albums_backup', JSON.stringify(albumes));
                
                // Mostrar éxito
                document.getElementById('loadingMsg').style.display = 'none';
                document.getElementById('successMsg').style.display = 'block';
                
                setTimeout(() => {
                    closeModal('createModal');
                    limpiarFormulario();
                    renderAlbumes();
                }, 1500);

            } catch (error) {
                console.error('❌ Error guardando:', error);
                alert('❌ Error al guardar: ' + error.message);
                
                btn.disabled = false;
                btn.innerHTML = textoOriginal;
                document.getElementById('loadingMsg').style.display = 'none';
            } finally {
                guardando = false;
            }
        }

        // Comprimir imagen para no saturar localStorage
        async function comprimirImagen(base64String) {
            return new Promise((resolve) => {
                const img = new Image();
                const canvas = document.createElement('canvas');
                const ctx = canvas.getContext('2d');

                img.onload = () => {
                    // Max 800px de ancho
                    const maxWidth = 800;
                    const scale = maxWidth / img.width;
                    const width = img.width > maxWidth ? maxWidth : img.width;
                    const height = img.width > maxWidth ? img.height * scale : img.height;

                    canvas.width = width;
                    canvas.height = height;
                    ctx.drawImage(img, 0, 0, width, height);

                    // Calidad 0.8 = buen balance calidad/peso
                    const compressed = canvas.toDataURL('image/jpeg', 0.8);
                    resolve(compressed);
                };

                img.src = base64String;
            });
        }

        // ==========================================
        // EDITAR ÁLBUM/CANCIÓN
        // ==========================================
        function editarAlbum(id) {
            if (modoEliminar) {
                desactivarModoEliminar();
            }

            const album = albumes.find(a => a.id === id);
            if (!album) {
                alert('❌ ÁLBUM/CANCIÓN no encontrado');
                return;
            }

            // Limpiar y llenar formulario
            limpiarFormulario();
            
            document.getElementById('albumId').value = id;
            document.getElementById('modalTitle').textContent = '✏️ Editar ÁLBUM/CANCIÓN';
            document.getElementById('albumTitle').value = album.title || '';
            document.getElementById('albumDesc').value = album.description || '';
            document.getElementById('linkSpotify').value = album.links?.spotify || '';
            document.getElementById('linkApple').value = album.links?.apple || '';
            document.getElementById('linkSoundCloud').value = album.links?.soundcloud || '';
            document.getElementById('linkYouTube').value = album.links?.youtube || '';
            document.getElementById('linkAudiomack').value = album.links?.audiomack || '';

            // Mostrar imagen si existe
            if (album.image && album.image !== 'https://i.ibb.co/C5mFsQnb/logozazahousestudiosoriginal.jpg') {
                fotoTemporal = album.image;
                document.getElementById('previewImg').src = album.image;
                document.getElementById('previewImg').style.display = 'block';
                document.getElementById('fileLabel').innerHTML = '📷 Cambiar imagen actual';
                document.getElementById('btnQuitarFoto').style.display = 'block';
            }

            document.getElementById('createModal').classList.add('active');
        }

        // ==========================================
        // ELIMINAR ÁLBUM/CANCIÓN
        // ==========================================
        function eliminarAlbum(id) {
            idAEliminar = id;
            const album = albumes.find(a => a.id === id);
            
            document.getElementById('confirmMessage').innerHTML = 
                `¿Eliminar permanentemente<br><strong style="color: var(--fuxia);">${album?.title || 'este ÁLBUM/CANCIÓN'}</strong>?`;
            
            document.getElementById('confirmModal').classList.add('active');
        }

        // Configurar botón de confirmación
        document.getElementById('btnConfirmarSi').addEventListener('click', async () => {
            if (!idAEliminar) {
                closeModal('confirmModal');
                return;
            }

            const id = idAEliminar;
            
            try {
                // Eliminar de Firebase
                if (db && !id.startsWith('local-')) {
                    try {
                        await db.ref('albums/' + id).remove();
                        console.log('✅ Eliminado de Firebase');
                    } catch (firebaseError) {
                        console.warn('⚠️ Error Firebase al eliminar:', firebaseError);
                    }
                }
                
                // Eliminar del array local
                albumes = albumes.filter(a => a.id !== id);
                localStorage.setItem('zazaboys_albums_backup', JSON.stringify(albumes));
                
                console.log('✅ ÁLBUM/CANCIÓN eliminado:', id);
                
                idAEliminar = null;
                closeModal('confirmModal');
                
                if (modoEliminar && albumes.length === 0) {
                    desactivarModoEliminar();
                }
                
                renderAlbumes();
                
            } catch (e) {
                console.error('❌ Error eliminando:', e);
                alert('❌ Error al eliminar: ' + e.message);
                idAEliminar = null;
                closeModal('confirmModal');
            }
        });

        // ==========================================
        // RENDERIZAR ÁLBUM/CANCIÓNES
        // ==========================================
        function renderAlbumes() {
            const container = document.getElementById('albumes-container');
            
            if (albumes.length === 0) {
                container.innerHTML = `
                    <div style="text-align: center; color: #666; padding: 60px 20px; grid-column: 1/-1;">
                        <div style="font-size: 4rem; margin-bottom: 20px;">🎵</div>
                        <p style="font-size: 1.2rem;">No hay ÁLBUM/CANCIÓNes aún</p>
                        ${isAdmin ? '' : ''}
                    </div>
                `;
                return;
            }

            container.innerHTML = albumes.map(album => {
                const links = [];
                
                if (album.links?.spotify) {
                    links.push(`<a href="${album.links.spotify}" target="_blank" class="btn-platform btn-spotify">
                        <img src="https://upload.wikimedia.org/wikipedia/commons/1/19/Spotify_logo_without_text.svg" alt="Spotify"> Spotify
                    </a>`);
                }
                if (album.links?.apple) {
                    links.push(`<a href="${album.links.apple}" target="_blank" class="btn-platform btn-apple">
                        <img src="https://upload.wikimedia.org/wikipedia/commons/f/fa/Apple_logo_black.svg" alt="Apple"> Apple
                    </a>`);
                }
                if (album.links?.soundcloud) {
                    links.push(`<a href="${album.links.soundcloud}" target="_blank" class="btn-platform btn-soundcloud">
                        <img src="https://cdn-icons-png.flaticon.com/512/145/145809.png" alt="SoundCloud"> SoundCloud
                    </a>`);
                }
                if (album.links?.youtube) {
                    links.push(`<a href="${album.links.youtube}" target="_blank" class="btn-platform btn-youtube">
                        <img src="https://upload.wikimedia.org/wikipedia/commons/e/ef/Youtube_logo.png" alt="YouTube"> YouTube
                    </a>`);
                }
                if (album.links?.audiomack) {
                    links.push(`<a href="${album.links.audiomack}" target="_blank" class="btn-platform btn-audiomack">
                        <img src="https://crystalpng.com/wp-content/uploads/2025/03/audiomack_logo.png" alt="Audiomack"> Audiomack
                    </a>`);
                }

                // Botones de admin
                const adminButtons = (isAdmin && !modoEliminar) ? `
                    <div class="admin-btns">
                        <button class="admin-btn edit" onclick="event.stopPropagation(); editarAlbum('${album.id}')" title="Editar">✏️</button>
                        <button class="admin-btn delete" onclick="event.stopPropagation(); eliminarAlbum('${album.id}')" title="Eliminar">🗑️</button>
                    </div>
                ` : '';

                // Overlay modo eliminar
                const eliminarOverlay = modoEliminar ? `
                    <div class="modo-eliminar-overlay" onclick="eliminarAlbum('${album.id}')">
                        <span class="modo-eliminar-badge">🗑️ TOCAR PARA ELIMINAR</span>
                    </div>
                ` : '';

                return `
                    <div class="album-zaza ${modoEliminar ? 'modo-eliminar-activo' : ''}">
                        ${eliminarOverlay}
                        ${adminButtons}
                        <div class="album-img-container">
                            <img src="${album.image}" alt="${album.title}" class="album-img" 
                                 onerror="this.src='https://i.ibb.co/C5mFsQnb/logozazahousestudiosoriginal.jpg'">
                            <div class="album-overlay"></div>
                        </div>
                        <div class="album-info">
                            <h3 class="album-title">${album.title}</h3>
                            <p class="album-desc">${album.description}</p>
                            <div class="botones-zaza">
                                ${links.length > 0 ? links.join('') : '<p style="color: #666; font-size: 0.9rem;">Disponible pronto en plataformas</p>'}
                            </div>
                        </div>
                    </div>
                `;
            }).join('');
        }

        // ==========================================
        // EVENT LISTENERS
        // ==========================================
        document.getElementById('passwordInput').addEventListener('keypress', function(e) {
            if (e.key === 'Enter') checkPassword();
        });

        // Cerrar modal al hacer clic fuera
        window.onclick = function(event) {
            if (event.target.classList.contains('modal-overlay')) {
                event.target.classList.remove('active');
            }
        }

        // ==========================================
        // INICIALIZACIÓN
        // ==========================================
        document.addEventListener('DOMContentLoaded', function() {
            console.log('🎵 ZAZABOYS iniciado');
            // Intentar cargar desde localStorage mientras Firebase conecta
            usarDatosLocales();
        });
    </script>
</body>

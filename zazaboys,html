                <input type="text" id="albumTitle" class="zaza-input" placeholder="Nombre del ÁLBUM/CANCIÓN o canción *">
                <textarea id="albumDesc" class="zaza-input" placeholder="Descripción del ÁLBUM/CANCIÓN..." rows="3"></textarea>
                
                <div style="border-top: 2px solid var(--fuxia); margin: 10px 0; padding-top: 15px;">
                    <h3 style="color: var(--verde); margin-bottom: 15px; text-align: center; font-size: 1.1rem;">🔗 Links de Plataformas</h3>
                    
                    <input type="text" id="linkSpotify" class="zaza-input" placeholder="Link de Spotify">
                    <input type="text" id="linkApple" class="zaza-input" placeholder="Link de Apple Music">
                    <input type="text" id="linkSoundCloud" class="zaza-input" placeholder="Link de SoundCloud">
                    <input type="text" id="linkYouTube" class="zaza-input" placeholder="Link de YouTube Music">
